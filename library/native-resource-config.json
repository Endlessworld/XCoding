{
  "resources": {
    "includes": [
      {
        "pattern": ".*\\.properties$"
      },
      {
        "pattern": ".*\\.xml$"
      },
      {
        "pattern": ".*\\.json$"
      },
      {
        "pattern": "META-INF/services/.*"
      },
      {
        "pattern": "META-INF/.*"
      },
      {
        "pattern": "prompt/.*"
      },
      {
        "pattern": ".*\\.md$"
      },
      {
        "pattern": ".*logback.*\\.xml$"
      },
      {
        "pattern": ".*spring.*\\.xml$"
      },
      {
        "pattern": ".*spring.*\\.properties$"
      }
    ]
  },
  "bundles": [
    {
      "name": "jakarta.servlet.LocalStrings"
    },
    {
      "name": "jakarta.servlet.http.LocalStrings"
    },
    {
      "name": "org.slf4j.LoggerFactory"
    },
    {
      "name": "ch.qos.logback.classic.Logger"
    }
  ]
}
